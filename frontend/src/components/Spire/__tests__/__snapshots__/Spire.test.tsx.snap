exports[`Spire component > Workload type > renders card with multiple identity matches 1`] = `
<div>
  <div
    class="pf-v6-c-card pf-m-compact"
    data-ouia-component-id="OUIA-Generated-Card-:r3:"
    data-ouia-component-type="PF6/Card"
    data-ouia-safe="true"
    id="SpireCard"
  >
    <div
      class="pf-v6-c-card__header"
    >
      <div
        class="pf-v6-c-card__header-main"
      >
        <h5
          class="pf-v6-c-title pf-m-lg"
          data-ouia-component-id="OUIA-Generated-Title-:r5:"
          data-ouia-component-type="PF6/Title"
          data-ouia-safe="true"
        >
          SPIRE
        </h5>
      </div>
    </div>
    <div
      class="pf-v6-c-card__body"
    >
      <div
        class="kiali_fz3g8mp"
      >
        <ul>
          <li>
            <span>
              Status
            </span>
            <div
              style="display: inline-block;"
            >
              This workload is using SPIRE (SPIFFE Runtime Environment) for identity management.
            </div>
          </li>
          <li
            style="margin-top: 0.5rem;"
          />
          <li>
            <span>
              Annotations
            </span>
            <div
              style="display: inline-block;"
            >
              <code
                class="kiali_f107x8dj"
              >
                inject.istio.io/templates: spire
              </code>
            </div>
          </li>
          <li
            style="margin-top: 0.25rem;"
          />
          <li>
            <span>
              Labels
            </span>
            <div
              style="display: inline-block;"
            >
              <code
                class="kiali_f107x8dj"
              >
                spiffe.io/spire-managed-identity: true
              </code>
            </div>
          </li>
          <li
            style="margin-top: 0.25rem;"
          />
          <li>
            <span>
              PodLabels
            </span>
            <div
              style="display: inline-block;"
            >
              <code
                class="kiali_f107x8dj"
              >
                spiffe.io/spire-managed-identity: true
              </code>
            </div>
          </li>
        </ul>
      </div>
    </div>
  </div>
</div>
`;

